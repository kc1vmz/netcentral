<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
  <changeSet id="01" author="kc1vmz">
    <createTable tableName="tile">
      <column name="tile_key" type="VARCHAR(30)">
        <constraints nullable="false" unique="true" primaryKey="true" primaryKeyName="tile_key_pk"/>
      </column>
      <column name="x" type="INT">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="y" type="INT">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="z" type="INT">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="fetch_time" type="VARCHAR(30)">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="data" type="blob">
        <constraints nullable="false" unique="false"/>
      </column>
    </createTable>
  </changeSet>
</databaseChangeLog>