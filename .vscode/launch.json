        {
            "type": "java",
            "name": "Net Central Server (MySQL)",
            "request": "launch",
            "mainClass": "netcentral.server.Application",
            "projectName": "netcentral-server",
            "vmArgs": ["-Dmicronaut.environments=mysql"]
        },
        {
            "type": "java",
            "name": "Net Central Server (H2)",
            "request": "launch",
            "mainClass": "netcentral.server.Application",
            "projectName": "netcentral-server",
            "vmArgs": ["-Dmicronaut.environments=h2"]
        },
        {
            "type": "java",
            "name": "OSM-Proxy-Cache",
            "request": "launch",
