        },
        {
            "type": "java",
            "name": "Transceiver-Kenwood",
            "request": "launch",
            "mainClass": "netcentral.transceiver.kenwood.Application",
            "projectName": "transceiver-kenwood"
        },
        {
            "type": "java",
            "name": "Transceiver-APRSIS",
            "request": "launch",
            "mainClass": "netcentral.transceiver.aprsis.Application",
            "projectName": "transceiver-aprsis"
        },
        {
            "type": "java",
            "name": "Transceiver-Test",
            "request": "launch",
            "mainClass": "netcentral.transceiver.test.Application",
            "projectName": "transceiver-test"
        },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
